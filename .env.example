# =============================
# CẤU HÌNH CHUNG
# =============================
HSMT_STRICT_PRIVACY=1
HSMT_ALLOW_NETWORK=0
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
DO_NOT_TRACK=1

HSMT_RUNTIME_ROOT=runtime/jobs
HSMT_JOB_RETENTION_HOURS=24
HSMT_MAX_UPLOAD_MB=2048
HSMT_MAX_EXCEL_ROWS=1000000

# Nhiều người có thể gửi tác vụ đồng thời.
# Với OCR CPU nên để 1-2; với máy mạnh có thể tăng thận trọng.
HSMT_MAX_CONCURRENT_JOBS=2

# =============================
# ĐỌC VÀ GHI EXCEL
# =============================
HSMT_EXCEL_READ_ENGINE=calamine
HSMT_EXCEL_READ_WORKERS=4
HSMT_EXCEL_WRITE_WORKERS=1
HSMT_EXCEL_SCAN_FORMULAS=1
HSMT_EXCEL_SCAN_EXTERNAL_LINKS=1
HSMT_EXCEL_FALLBACK_OPENPYXL=1

# =============================
# GHÉP TÊN HẠNG MỤC
# =============================
HSMT_ENABLE_EMBEDDINGS=0
HSMT_ENABLE_RERANKER=0
HSMT_MODEL_ROOT=models
HSMT_EMBEDDING_MODEL=
HSMT_RERANKER_MODEL=
HSMT_EMBED_BATCH=32
HSMT_RERANK_BATCH=16
HSMT_FUZZY_TOP_K=8
HSMT_SEMANTIC_TOP_K=5

# =============================
# OCR MẶC ĐỊNH - DỄ CHẠY TRÊN CPU
# =============================
HSMT_OCR_ACCURACY_MODE=balanced
HSMT_OCR_PROFILE=dense_boq
HSMT_OCR_DEVICE=cpu
HSMT_OCR_DPI=400
HSMT_OCR_UPSCALE=3.5
HSMT_OCR_BATCH_SIZE=32
HSMT_OCR_WORKERS=1
HSMT_MAX_PDF_PAGES=500
HSMT_OCR_MAX_FILE_GB=2
HSMT_OCR_MIN_TEXT_CONF=0.82
HSMT_OCR_MIN_NUMERIC_CONF=0.90
HSMT_OCR_MATH_TOLERANCE=0.005
HSMT_OCR_COMPONENT_TOLERANCE=0.01
HSMT_OCR_ARITHMETIC_RECONCILIATION=1
HSMT_OCR_SAVE_REVIEW_IMAGES=1
HSMT_OCR_ALLOW_TESSERACT_ONLY=1

# Tự nhận biết trang bị lộn ngược 180 độ bằng tiêu đề/ngữ nghĩa OCR.
HSMT_OCR_USE_OSD=1
HSMT_OCR_ORIENTATION_PROBE=1
HSMT_OCR_ORIENTATION_TOP_RATIO=0.30
HSMT_OCR_ORIENTATION_TARGET_WIDTH=3000
HSMT_OCR_ORIENTATION_MIN_GAP=6.0
HSMT_OCR_ORIENTATION_TIMEOUT=20

# Windows: sửa đường dẫn nếu Tesseract không nằm trong PATH.
TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe

# =============================
# OCR NÂNG CAO - CHỈ ĐIỀN KHI ĐÃ CÓ MODEL LOCAL
# =============================
HSMT_USE_TABLEMAGIC=1
HSMT_USE_PPSTRUCTURE=1
HSMT_USE_PADDLE_VL=1
HSMT_USE_VL_UNCERTAIN_TABLES=1
HSMT_PADDLE_OCR_YAML=
HSMT_PADDLE_REC_MODEL_DIR=
HSMT_PADDLE_REC_MODEL_NAME=PP-OCRv6_medium_rec
HSMT_TABLEMAGIC_YAML=
HSMT_PPSTRUCTURE_YAML=
HSMT_PADDLE_VL_VERSION=v1.6
HSMT_PADDLE_VL_YAML=
HSMT_PADDLE_VL_LAYOUT_MODEL_DIR=
HSMT_PADDLE_VL_MODEL_DIR=
HSMT_PADDLE_VL_BACKEND=
HSMT_PADDLE_VL_SERVER_URL=
HSMT_PADDLE_VL_API_MODEL_NAME=PaddlePaddle/PaddleOCR-VL-1.6
HSMT_PADDLE_VL_MAX_CONCURRENCY=1

# =============================
# CHẠY WEB
# =============================
HSMT_PYTHON=python
HSMT_WEB_HOST=0.0.0.0
HSMT_WEB_PORT=8004
